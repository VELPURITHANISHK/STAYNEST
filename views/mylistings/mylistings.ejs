<link rel="stylesheet" href="/css/mylisting.css"> 

<h1 class="mb-4">My Listings</h1>

<% if(listings.length===0){ %>

<div class="alert alert-info text-center mt-4">
    No listings created
</div>

<% } %>


<div class="row">

<% listings.forEach(listing=>{ %>

<div class="col-lg-6 mb-4">

<div class="card shadow-sm h-100">

<div class="row g-0 h-100">

<div class="col-md-4">

<img
src="<%= listing.image.url %>"
class="img-fluid h-100 w-100 object-fit-cover rounded-start"
alt="<%= listing.title %>"
>

</div>


<div class="col-md-8">

<div class="card-body d-flex flex-column h-100">

<a
href="/listing/<%= listing._id %>"
class="text-decoration-none text-dark"
>

<h4 class="card-title">
<%= listing.title %>
</h4>

</a>

<h5 class="mt-2 text-success">
&#8377; <%= listing.price.toLocaleString("en-IN") %>/night
</h5>

<p class="text-muted mt-2">
<i class="fa-solid fa-location-dot"></i>&nbsp; <%= listing.location %>,
<%= listing.country %>
</p>

<div class="mt-auto">

<a
href="/listing/<%= listing._id %>"
class="btn btn-dark"
>
View Details
</a>

</div>

</div>

</div>

</div>

</div>

</div>

<% }) %>

</div>