<% layout("layouts/boilerplate") -%>

    <div class="row">
        <div class="col-8 offset-3 mb-2 mt-4"> 
             <h3 class="card-text"><b><%= showing.title %></b></h3>
             <br>
        </div>
    <div class="card col-6 offset-3 show-imge listing-card">
        
        <img src="<%=showing.image.url%>" class="card-img-top show-image" alt="shoiwing_image"><br>
        <div class="card-body">
            <i>Owned by : <%= showing.owner.username %></i>
            <br>
            <b><%= showing.description %></b>
            <br>
           <b> &#8377;<%=showing.price.toLocaleString("en-IN") %></b>
            <br>
           <b> <i class="fa-solid fa-location-dot"></i>&nbsp;&nbsp;<%= showing.location %></b>
            <br>
           <b> <%= showing.country %></b>
            <br><br>
            <a href="/listing/<%= showing._id %>/booking" class="btn btn-primary offset-9 b-button"> Book Now</a>
            <br>
            
        </div>
    </div>
   
    <% if(currUser && currUser._id.equals(showing.owner._id)){ %>
    <div class="btns">
        <a href="/listing/<%= showing._id %>/edit"  class="btn btn-dark  offset-3 edit-bttn-2 e-button">Edit</a>
   
        <form method="POST" action="/listing/<%= showing._id %>?_method=DELETE">

                <button class="btn btn-dark offset-8 del-bttn-2 d-button">Delete</button>

        </form>
    </div>
   
    <% } %>

    <div class="col-8 offset-3 mb-2 mt-2">
        
        <% if(currUser) { %>
            <hr>
        <h4>Leave a Review</h4>
        <form action="/listing/<%= showing._id %>/reviews" method="post" novalidate class="needs-validation">
           
            <div class="mb-3">
            <label for="rating" class="form-label"><h5>Rating</h5></label>
            <fieldset class="starability-fade">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked/>
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3"  />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            
            </div>
            
            <br>
            <div class="mb-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea class="form-control" cols="30" rows="5" name="review[comment]" id="comment" required></textarea>
                <div class="invalid-feedback">
                    Please submit some comments for review
                </div>

            </div>
            <button class="btn btn-outline-dark s-button" >Submit</button>
        </form>
        
        <% } %>
        
        <hr>

       
        
       <% if(showing.reviews.length > 0) {%>

       <div class="row">
        <p><b>All Reviews</b></p>
            <% for(review of showing.reviews){ %>
            <div class="card col-5 mb-3 ms-3 review-card">
                <div class="card-body">
                    <h5 class="card-title"><%= review.author.username %></h5>
                    <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>   
                    <p class="card-text"> <%= review.comment %></p>
                    
                    <% if(currUser && currUser._id.equals(review.author._id)){ %>
                    <form class="mb-2" action="/listing/<%= showing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" >
                        <button class="btn btn-sm btn-dark d-button">Delete</button>
                    </form>
                       <% } %>
                </div>
            </div>
            
        <% } %>

        </div>
           <% } %>
</div>

 <div class="col-6 offset-3 mb-3">
    <h4>Where you'll be</h4>

    <div id="map">
        
    </div>
</div>




<script>
const coordinates = {
    lat: <%= showing.geometry.coordinates[1] %>,
    lng: <%= showing.geometry.coordinates[0] %>
};
</script>

<script src="/js/map.js"></script>

<script
src="https://maps.googleapis.com/maps/api/js?key=<%= googleApiKey %>&callback=initMap"
async
defer>
</script>
